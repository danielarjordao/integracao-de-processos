#IMAGEM BASE
FROM node:20-alpine

#DIRETORIA DE TRABALHO (ONDE CORREM OS SCRIPTS -> RUN)
WORKDIR /usr/src/app

#COPIAR FICHEIROS PARA A IMAGEM
COPY . .

#CORRE NPM INSTALL -> INSTALA PACKAGES (ENQUANTO FAZ BUILD)
RUN npm install

#EXPOR PORTA
EXPOSE 4200
#COMANDOS A CORRER NO FIM DO BUILD
CMD ["sh"]